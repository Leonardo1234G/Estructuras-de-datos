#include <iostream>
#include <string>

using namespace std;

//presentacion de la clase
class Saludo {
    private: //atributos
        string mensaje = "Hola Mundo";
    public : //metodos
        void mostrar() {
        cout << mensaje;
    }
};
int main()
{
    //Declarar un objeto de la clase Saludo se llama saludito
    Saludo saludito;
    saludito.mostrar(); //utilizacion de un metodo de clase
    return 0;
}
