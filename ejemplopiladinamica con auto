//NODO.H
#include <iostream>
#include <stdlib.h>
#include <string>
#pragma once

using namespace std;

class Nodo {
public:
	int id;
	string marca;
	string modelo;
	int anio;
	string color;
	Nodo* sig;

};
//PILA.H
#include "Nodo.h"


class Pila {
    Nodo* inicio;
public:
    Pila() {
        inicio = NULL;
    }
    void push();
    void pop();
    void show();
    void top();
    void size();
};
//PILA CPP
#include "Pila.h"
#include <iostream>
#include <string>

using namespace std;

void Pila::push() {
    Nodo* aux = new Nodo;

    system("cls");
    cout << "Ingresa el ID del auto: ";
    cin >> aux->id;

    cin.ignore();
    cout << "Ingresa la marca: ";
    getline(cin, aux->marca);

    cout << "Ingresa el modelo: ";
    getline(cin, aux->modelo);

    cout << "Ingresa el año: ";
    cin >> aux->anio;

    cin.ignore();
    cout << "Ingresa el color: ";
    getline(cin, aux->color);

    aux->sig = NULL;

    if (inicio != NULL)
        aux->sig = inicio;

    inicio = aux;

    cout << "\nAuto insertado en la pila!\n";
    system("pause");
}


void Pila::pop() {
    Nodo* temp = new Nodo;
    if (inicio == NULL) {
        system("cls");
        cout << "\nLa pila esta vacia!\n\n";
        system("pause");
    }
    else {
        temp = inicio;
        inicio = inicio->sig;
        system("cls");
        cout << "\nAuto eliminado:\n";
        cout << "ID: " << temp->id << endl;
        cout << "Marca: " << temp->marca << endl;
        cout << "Modelo: " << temp->modelo << endl;
        cout << "Anio: " << temp->anio << endl;
        cout << "Color: " << temp->color << endl;

        delete temp;
        system("pause");
    }
}

void Pila::show() {
    Nodo* aux1 = inicio;

    if (inicio == NULL) {
        system("cls");
        cout << "\nLa pila esta vacia!\n\n";
        system("pause");
    }
    else {
        system("cls");
        cout << "Autos en la pila:\n" << endl;

        while (aux1 != NULL) {
            cout << "ID: " << aux1->id << endl;
            cout << "Marca: " << aux1->marca << endl;
            cout << "Modelo: " << aux1->modelo << endl;
            cout << "Anio: " << aux1->anio << endl;
            cout << "Color: " << aux1->color << endl;
            cout << "------------------------\n";

            aux1 = aux1->sig;
        }

        system("pause");
    }
}


void Pila::top() {
    if (inicio == NULL) {
        system("cls");
        cout << "\nLa pila esta vacia!\n\n";
        system("pause");
    }
    else {
        system("cls");
        cout << "Auto en TOP:\n\n";

        cout << "ID: " << inicio->id << endl;
        cout << "Marca: " << inicio->marca << endl;
        cout << "Modelo: " << inicio->modelo << endl;
        cout << "Anio: " << inicio->anio << endl;
        cout << "Color: " << inicio->color << endl;

        system("pause");
    }
}


void Pila::size() {
    Nodo* aux1 = inicio;

    if (inicio == NULL) {
        system("cls");
        cout << "\nLa pila esta vacia!\n\n";
        system("pause");
    }
    else {
        int contador = 0;

        while (aux1) {
            contador++;
            aux1 = aux1->sig;
        }

        system("cls");
        cout << "El tamano de la pila es: " << contador << "\n" << endl;
        system("pause");
    }
}
//INT MAIN
#include <iostream>
#include <string>
#include "Nodo.h"
#include "Pila.h"

using namespace std;

int main() {
    Pila l;
    int opcion;
    do {
        system("cls");
        cout << "[:]Pila en lista enlazada" << endl;
        cout << "[1]Push" << endl;
        cout << "[2]Pop" << endl;
        cout << "[3]Mostrar" << endl;
        cout << "[4]Top" << endl;
        cout << "[5]Size" << endl;
        cout << "[0]Salir" << endl;
        cout << "\nIngresa tu opcion: ";
        cin >> opcion;
        switch (opcion) {
        case 1:
            l.push();
            break;
        case 2:
            l.pop();
            break;
        case 3:
            l.show();
            break;
        case 4:
            l.top();
            break;
        case 5:
            l.size();
            break;
        case 0:
            return 0;
            break;
        default:
            cout << "Por favor ingresa una opcion correcta.\n";
            break;
        }
    } while (opcion != 0);
    return 0;
}
