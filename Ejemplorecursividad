#include <iostream>
#include <cmath>
#include <stdlib.h> //libreria para correr comandos de windows
using namespace std;
int factorial(int n);
int sumatabla(int a, int b);
int serie(int n);


int main() {
	int opcion,a,b;
	system("color 5");

	do {
		cout << "1. Factorial" << endl;
		cout << "2. Impresion de la tabla de sumar decimal del (1 al 10)" << endl;
		cout << "3. Calcular la serie con ciclo For" << endl;
		cout << "0. Salir" << endl;
		cout << "Opción: ";
		cin >> opcion;

		switch (opcion) {
		case 1:
			int num;
			cout << "Ingrese el numero a calcular el factorial: ";
			cin >> num;
			cout << "El factorial de " << num << " es: " << factorial(num) << endl;
		       break;
		case 2: {
			int i, j;

			for (i = 1; i <= 10; i++)
			{
				for (j = 1; j <= 10; j++)
				{
					cout << i << " + " << j << " = "
						<< sumatabla(i, j) << "\t";
				}
				cout << endl;
			}
			break;
		}
		case 3: {
			int n;

			cout << "Ingrese el valor de n: ";
			cin >> n;
			cout << "La suma de la serie es: " << serie(n) << endl;

			break;
		}
		case 0:
			cout << "¡Hasta luego!\n";
			return 0;
			break;
		default:
			cout << "Opción no válida. Intenta de nuevo.\n";
			break;
		}
		system("pause");
		system("cls");

	} while (opcion != 0);

	return 0;
}


int factorial(int n) {
	if ((n == 0) || (n == 1))
		return 1;
	else
		return factorial(n - 1) * n;
}


int sumatabla(int a, int b)
{
	if (b == 0)
		return a;
	else
		return 1 + sumatabla(a, b - 1);
}

int serie(int n) {
	int suma = 0;

	if (n <= 0)   
		return 0;

	for (int i = n; i <= n; i++) {  
		suma = i + serie(n - 1);    
	}

	return suma;
}

