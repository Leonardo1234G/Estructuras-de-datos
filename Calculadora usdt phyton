import tkinter as tk
from tkinter import messagebox

# --- CONFIGURACIÓN DE COLORES ---
COLOR_FONDO = "#FFCC80"       # Negro azulado
COLOR_TARJETA = "#1E1E1E"     # 
COLOR_TEXTO_TITULO = "#00D4FF" # 
COLOR_TEXTO_LABELS = "#075E54" # 
COLOR_INPUTS = "#2C2C2C"      # 
COLOR_BOTON_BS = "#003366"    # 
COLOR_BOTON_SOLES = "#0050EF" # 
COLOR_RESULTADO = "#A20025"   

def bolivianos_a_soles():
    try:
        bolivianos = float(entry_monto.get())
        compra_usdt_bs = float(entry_compra_usdt_bs.get())
        venta_usdt_soles = float(entry_venta_usdt_soles.get())
        porcentaje_comision = float(entry_comision.get())

        # Cálculo de la transformación principal
        usdt_brutos = bolivianos / compra_usdt_bs
        soles_brutos = usdt_brutos * venta_usdt_soles
        
        # Cálculo de comisión
        comision_soles = soles_brutos * (porcentaje_comision / 100)
        soles_finales = soles_brutos - comision_soles
        
        # Comisión convertida a otras monedas
        comision_usdt = comision_soles / venta_usdt_soles
        comision_bs = comision_usdt * compra_usdt_bs

        resultado.set(
            f"Monto: {usdt_brutos:.4f} USDT\n"
            f"Recibes: S/ {soles_finales:.2f} (Neto)\n"
            f"------------------------------------------\n"
            f"COMISIÓN:\n"
            f"S/ {comision_soles:.2f} | {comision_usdt:.4f} USDT | Bs {comision_bs:.2f}"
        )

    except ValueError:
        messagebox.showerror("Error", "Ingrese solo números válidos.")
    except ZeroDivisionError:
        messagebox.showerror("Error", "Los precios no pueden ser cero.")

def soles_a_bolivianos():
    try:
        soles_objetivo = float(entry_monto.get())
        compra_usdt_bs = float(entry_compra_usdt_bs.get())
        venta_usdt_soles = float(entry_venta_usdt_soles.get())
        porcentaje_comision = float(entry_comision.get())

        # Cálculo para recibir monto neto
        soles_brutos = soles_objetivo / (1 - (porcentaje_comision / 100))
        usdt_necesarios = soles_brutos / venta_usdt_soles
        bolivianos_totales = usdt_necesarios * compra_usdt_bs
        
        # Cálculo de comisión
        comision_soles = soles_brutos - soles_objetivo
        comision_usdt = comision_soles / venta_usdt_soles
        comision_bs = comision_usdt * compra_usdt_bs

        resultado.set(
            f"Necesitas: {usdt_necesarios:.4f} USDT\n"
            f"Depositar: Bs {bolivianos_totales:.2f}\n"
            f"------------------------------------------\n"
            f"COMISIÓN:\n"
            f"S/ {comision_soles:.2f} | {comision_usdt:.4f} USDT | Bs {comision_bs:.2f}"
        )

    except ValueError:
        messagebox.showerror("Error", "Ingrese solo números válidos.")
    except ZeroDivisionError:
        messagebox.showerror("Error", "Los precios no pueden ser cero.")

# --- VENTANA PRINCIPAL ---
ventana = tk.Tk()
ventana.title("Calculadora Cambista Pro")
ventana.geometry("500x600")
ventana.resizable(False, False)
ventana.config(bg=COLOR_FONDO)

# Título
tk.Label(
    ventana, 
    text="Calculadora Bs ⇄ USDT ⇄ Soles", 
    font=("Arial", 16, "bold"),
    bg=COLOR_FONDO,
    fg=COLOR_TEXTO_TITULO
).pack(pady=20)

# Función para crear campos con el estilo nuevo
def crear_campo(texto):
    tk.Label(ventana, text=texto, font=("Arial", 10, "bold"), bg=COLOR_FONDO, fg=COLOR_TEXTO_LABELS).pack()
    ent = tk.Entry(
        ventana, 
        font=("Arial", 12), 
        justify="center",
        bg=COLOR_INPUTS,
        fg="white",
        insertbackground="white", # Color del cursor
        relief="flat",
        borderwidth=5
    )
    ent.pack(pady=5)
    return ent

entry_monto = crear_campo("Monto a enviar (Bs) o recibir (Soles):")
entry_compra_usdt_bs = crear_campo("Precio compra 1 USDT en Bolivianos:")
entry_venta_usdt_soles = crear_campo("Precio venta 1 USDT en Soles:")

tk.Label(ventana, text="% Comisión del Cambista:", font=("Arial", 10, "bold"), bg=COLOR_FONDO, fg=COLOR_TEXTO_LABELS).pack()
entry_comision = tk.Entry(ventana, font=("Arial", 12), justify="center", bg=COLOR_INPUTS, fg="white", insertbackground="white", relief="flat")
entry_comision.insert(0, "0")
entry_comision.pack(pady=5)

# --- BOTONES ---
frame_botones = tk.Frame(ventana, bg=COLOR_FONDO)
frame_botones.pack(pady=20)

tk.Button(
    frame_botones, 
    text="Bs a Soles", 
    font=("Arial", 10, "bold"), 
    bg=COLOR_BOTON_BS, 
    fg="white", 
    width=18, 
    height=2,
    relief="flat",
    command=bolivianos_a_soles
).grid(row=0, column=0, padx=10)

tk.Button(
    frame_botones, 
    text="Soles a Bs", 
    font=("Arial", 10, "bold"), 
    bg=COLOR_BOTON_SOLES, 
    fg="white", 
    width=18, 
    height=2,
    relief="flat",
    command=soles_a_bolivianos
).grid(row=0, column=1, padx=10)

# --- ÁREA DE RESULTADO ---
resultado = tk.StringVar()
resultado.set("Esperando cálculos...")

tk.Label(
    ventana, 
    textvariable=resultado, 
    font=("Consolas", 11, "bold"), 
    justify="center", 
    fg=COLOR_RESULTADO,
    bg=COLOR_TARJETA,
    relief="flat",
    padx=15,
    pady=15,
    width=50
).pack(pady=10, padx=20)

# Créditos
tk.Label(
    ventana, 
    text="Cálculo basado en arbitraje Cripto / P2P", 
    font=("Arial", 8), 
    bg=COLOR_FONDO,
    fg="gray"
).pack(side="bottom", pady=10)

ventana.mainloop()
